# Backend sozlamalari
APP_NAME=Onix Platform
SECRET_KEY=change-me-to-a-long-random-string-please
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Boshliq (admin) login - dashboard kirish uchun
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database
DATABASE_URL=sqlite:///./onix.db
# VPS uchun: DATABASE_URL=postgresql+psycopg://user:pass@localhost/onix

# Telegram API - https://my.telegram.org dan oling
# (har bir userbot account uchun bir xil API_ID/API_HASH ishlatiladi)
TG_API_ID=
TG_API_HASH=

# CORS - frontend URL
CORS_ORIGINS=http://localhost:3000

# Telethon session papkasi
SESSIONS_DIR=./sessions

# Rate limit (ban xavfini kamaytirish uchun)
JOIN_DELAY_SECONDS=60
DM_DELAY_SECONDS=30
GROUP_POST_DELAY_SECONDS=120
